# Database
DATABASE_URL=postgresql+psycopg2://career_agent:career_agent@localhost:5432/career_agent
REDIS_URL=redis://localhost:6379/0

# AI Providers (at least one required)
NVIDIA_API_KEY=nvapi-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Primary AI Provider: nvidia | openai | deepseek | anthropic
PRIMARY_AI_PROVIDER=nvidia

# App Settings
APP_NAME=Combo AI Agent
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# Browser Automation
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=500

# Scraping
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.0
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=2

# Email / Outreach (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Job Search Defaults
DEFAULT_CITY=Hyderabad
DEFAULT_SKILLS=Python,SQL,Data Analysis
